# ─── Database (Neon Postgres + pgvector) ───────────────────────────────
# Pooled connection string from Neon dashboard (used by serverless driver)
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ─── LLM provider ──────────────────────────────────────────────────────
# "groq" | "gemini" | "openrouter" — which chat backend to use.
# Embeddings ALWAYS use Gemini (Groq has no embeddings endpoint).
#   groq      = free tier, high daily limits — recommended for the backfill
#   gemini    = free tier ~1500/day (region/project dependent)
#   openrouter= 50/day on free models unless you add credit
LLM_PROVIDER=groq

# ─── Groq (chat) ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# ─── Embeddings ────────────────────────────────────────────────────────
# "jina" (free HTTP API, keeps 768 dims, works local + serverless) or "gemini".
EMBED_PROVIDER=jina
JINA_API_KEY=jina_...
JINA_MODEL=jina-embeddings-v3

# ─── Gemini (embeddings + chat when LLM_PROVIDER=gemini) ───────────────
GEMINI_API_KEY=...
GEMINI_EMBED_MODEL=text-embedding-004
# Chat models for classify/summarize (fast) and /ask + weekly report (smart).
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_SMART=gemini-2.0-flash

# ─── LLM (OpenRouter) — only used when LLM_PROVIDER=openrouter ──────────
OPENROUTER_API_KEY=sk-or-v1-...
# Cheap/free model for high-volume classify + summarize during backfill
OPENROUTER_MODEL_FAST=google/gemini-2.0-flash-exp:free
# Higher-quality model for /ask answers + weekly trend report
OPENROUTER_MODEL_SMART=anthropic/claude-3.5-sonnet
# Sent as HTTP-Referer/X-Title for OpenRouter attribution (optional)
OPENROUTER_SITE_URL=https://radar.yourdomain.com
OPENROUTER_SITE_NAME=Research Radar

# ─── Background jobs (Inngest) ─────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Slack ─────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_DIGEST_CHANNEL=C0XXXXXXX

# ─── Discord ───────────────────────────────────────────────────────────
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_DIGEST_WEBHOOK_URL=

# ─── Notion (KB mirror) ────────────────────────────────────────────────
NOTION_TOKEN=ntn_...
NOTION_DB_ID=

# ─── Semantic Scholar (optional API key for higher rate limits) ────────
S2_API_KEY=

# ─── Misc ──────────────────────────────────────────────────────────────
# Earliest month to backfill to (inclusive), YYYY-MM
BACKFILL_SINCE=2025-01
# Comma-separated arXiv categories to crawl
ARXIV_CATEGORIES=cs.LG,cs.CL,cs.AI
